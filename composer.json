{
    "name": "axelpal/sellerstore",
    "type": "project",
    "license": "Proprietary",
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "ext-simplexml": "*",
        "diglactic/laravel-breadcrumbs": "^10.0",
        "eusonlito/laravel-meta": "^3.1",
        "filament/filament": "^5.3.5",
        "guzzlehttp/guzzle": "^7.8",
        "iamcal/lib_autolink": "^1.9",
        "laravel/framework": "^11.28",
        "laravel/horizon": "^5.30",
        "laravel/tinker": "^2.10",
        "paquettg/php-html-parser": "^3.1",
        "predis/predis": "^2.3",
        "sentry/sentry-laravel": "^4.13",
        "spatie/laravel-responsecache": "^7.6",
        "stevegrunwell/time-constants": "^1.2"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.14",
        "barryvdh/laravel-ide-helper": "^3.0",
        "beyondcode/laravel-dump-server": "^2.1",
        "fakerphp/faker": "^1.24",
        "filp/whoops": "^2.16",
        "mockery/mockery": "^1.6",
        "larastan/larastan": "^3.0",
        "nunomaduro/collision": "^8.1",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "roave/security-advisories": "dev-latest",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.3.20",
            "ext-pcntl": "8.3.0",
            "ext-posix": "8.3.0",
            "ext-fileinfo": "8.3.0",
            "ext-intl": "8.3.0",
            "ext-zip": "8.3.0"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "stubs": [
            "@php artisan ide-helper:generate"
        ]
    },
    "repositories": []
}
